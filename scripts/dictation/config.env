# whisper.cpp dictation (Raspberry Pi 5 defaults)
# WHISPER_HOME is auto-detected — only set if needed:
# WHISPER_HOME=/home/you/whisper.cpp
WHISPER_MODEL="base.en-q5_1"
WHISPER_THREADS="4"

# Toggle: Ctrl+Space starts recording, Ctrl+Space again stops and pastes.
# Set HOTKEY_MODE=hold to use hold-to-talk instead.
HOTKEY_MODE="toggle"
HOTKEY_MODIFIERS="ctrl"
HOTKEY_KEY="space"

# PulseAudio/PipeWire source name (pactl list sources short). Empty = system default.
AUDIO_SOURCE="alsa_input.usb-MUSIC-BOOST_usb_microphone-00.mono-fallback"

MIN_RECORD_SEC="0.4"
INSERT_METHOD="clipboard"
